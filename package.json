{
  "name": "my-blog",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "new-post": "node scripts/new-post.mjs",
    "check-links": "node scripts/check-links.mjs",
    "perf-budget": "node scripts/perf-budget.mjs",
    "backup": "node scripts/backup.mjs",
    "lint:md": "markdownlint 'src/content/blog/**/*.md'",
    "lint:html": "html-validate 'dist/**/*.html'",
    "lighthouse": "lhci autorun",
    "validate": "npm run build && npm run check-links && npm run perf-budget"
  },
  "dependencies": {
    "@astrojs/mdx": "^3.1.3",
    "@astrojs/react": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "3.2.1",
    "@astrojs/tailwind": "^5.1.4",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.50",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.15",
    "astro": "^4.16.18",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-gfm": "^4.0.1",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "html-validate": "^10.11.3",
    "markdownlint-cli": "^0.48.0",
    "pagefind": "^1.5.0"
  }
}
