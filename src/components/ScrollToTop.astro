---
/**
 * Scroll-to-top button — appears after scrolling 400px down.
 * Smooth scrolls back to top on click.
 */
---

<button
  id="scroll-to-top"
  aria-label="Scroll to top"
  class="dark:!bg-[#a8d3bf] dark:!text-[#0f3d32]"
  style="display:none;position:fixed;bottom:24px;right:24px;z-index:90;width:44px;height:44px;border-radius:50%;border:none;cursor:pointer;background-color:#0f3d32;color:white;font-size:18px;box-shadow:0 2px 8px rgba(0,0,0,0.2);transition:opacity 200ms ease,transform 200ms ease;"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin:auto;display:block;">
    <path d="M18 15l-6-6-6 6"/>
  </svg>
</button>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var btn = document.getElementById('scroll-to-top');
    if (!btn) return;

    var visible = false;

    function toggle() {
      var shouldShow = (window.scrollY || window.pageYOffset) > 400;
      if (shouldShow !== visible) {
        visible = shouldShow;
        btn.style.display = visible ? 'block' : 'none';
      }
    }

    var ticking = false;
    window.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(function () { toggle(); ticking = false; });
        ticking = true;
      }
    }, { passive: true });

    btn.addEventListener('click', function () {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    toggle();
  });
</script>
