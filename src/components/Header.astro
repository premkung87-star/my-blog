---
import ThemeToggle from './ThemeToggle.astro';
import SearchModal from './SearchModal.astro';

const navLinks = [
  { href: '/blog',        label: 'BLOG'       },
  { href: '/books',       label: 'BOOKS'      },
  { href: '/categories',  label: 'CATEGORIES' },
  { href: '/verdex',      label: 'VERDEX'     },
  { href: '/now',         label: 'NOW'        },
  { href: '/about',       label: 'ABOUT'      },
  { href: '/contact',     label: 'CONTACT'    },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="fixed top-0 w-full z-50 backdrop-blur-md" style="background: rgba(250,250,250,0.8); box-shadow: 0 4px 32px rgba(15,61,50,0.04);">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <div class="flex items-center gap-8">
      <a href="/" class="flex items-center gap-3 transition-opacity duration-150 hover:opacity-70">
        <img src="/verdex-icon.png" alt="VerdeX" class="avatar-circle" style="height: 28px; width: 28px; object-fit: cover;" />
        <span class="font-display font-bold text-xl tracking-widest" style="color: var(--color-primary);">VERDEX_OS</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Primary navigation">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'font-display text-xs tracking-tight uppercase transition-colors duration-200 py-2',
              isActive(href)
                ? 'border-b-2 pb-1'
                : 'opacity-50 hover:opacity-100',
            ]}
            style={isActive(href) ? 'color: #2E7D32; border-color: #2E7D32;' : 'color: var(--color-primary);'}
          >
            {label}
          </a>
        ))}
      </nav>
    </div>

    <!-- Right side -->
    <div class="flex items-center gap-2">
      <SearchModal />
      <ThemeToggle />
      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 transition-colors duration-200 hover:bg-[#A8D3BF]/10"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

  </div>
</header>

<!-- Dark mode header override -->
<style>
  :global(.dark) header {
    background: rgba(15, 61, 50, 0.85) !important;
    box-shadow: none !important;
  }
</style>

<!-- Fullscreen mobile menu -->
<div id="mobile-menu" class="mobile-menu-overlay" aria-hidden="true">
  <div class="mobile-menu-inner">
    <button id="mobile-menu-close" class="absolute top-5 right-5 p-2" aria-label="Close menu" style="color: #A8D3BF;">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <p class="font-mono text-[10px] tracking-[0.3em] mb-10 uppercase" style="color: #A8D3BF; opacity: 0.4;">// NAVIGATION_MENU</p>

    <nav class="flex flex-col gap-0" aria-label="Mobile navigation">
      {navLinks.map(({ href, label }, i) => (
        <a
          href={href}
          class:list={['mobile-nav-link', isActive(href) ? 'active' : '']}
        >
          <span class="nav-index">{String(i + 1).padStart(2, '0')}</span>
          <span>{label}</span>
        </a>
      ))}
    </nav>

    <div class="absolute bottom-8 left-8">
      <p class="font-mono text-[10px] tracking-widest uppercase" style="color: #A8D3BF; opacity: 0.25;">
        VERDEX_OS v1.0 // CHIANG_MAI
      </p>
    </div>
  </div>
</div>

<style>
  .mobile-menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background-color: #0F3D32;
    display: none;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .mobile-menu-overlay.open {
    display: block;
    opacity: 1;
  }
  .mobile-menu-inner {
    position: relative;
    padding: 72px 32px;
    height: 100%;
  }
  .mobile-nav-link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 0;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.15s ease;
    border-bottom: 1px solid rgba(168, 211, 191, 0.08);
  }
  .mobile-nav-link:hover, .mobile-nav-link.active {
    color: #A8D3BF;
  }
  .nav-index {
    font-family: var(--font-mono);
    font-size: 11px;
    color: #2E7D32;
    opacity: 0.5;
    min-width: 24px;
  }
  @media (min-width: 768px) {
    .mobile-menu-overlay { display: none !important; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var btn = document.getElementById('mobile-menu-btn');
    var menu = document.getElementById('mobile-menu');
    var closeBtn = document.getElementById('mobile-menu-close');
    if (!btn || !menu || !closeBtn) return;

    function open() {
      menu.style.display = 'block';
      requestAnimationFrame(function () { menu.classList.add('open'); });
      menu.setAttribute('aria-hidden', 'false');
      btn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      menu.classList.remove('open');
      menu.setAttribute('aria-hidden', 'true');
      btn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      setTimeout(function () { menu.style.display = 'none'; }, 250);
    }

    btn.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && menu.classList.contains('open')) close();
    });
  });
</script>
