---
import ThemeToggle from './ThemeToggle.astro';
import SearchModal from './SearchModal.astro';

const navLinks = [
  { href: '/blog',        label: 'Blog'       },
  { href: '/books',       label: 'Books'      },
  { href: '/categories',  label: 'Categories' },
  { href: '/verdex',      label: 'VerdeX'     },
  { href: '/now',         label: 'Now'        },
  { href: '/about',       label: 'About'      },
  { href: '/contact',     label: 'Contact'    },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-[#F5F5F0]/80 dark:bg-stone-950/80 backdrop-blur-sm border-b border-stone-300/40 dark:border-stone-800/60">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">

    <!-- VerdeX logo -->
    <a href="/" class="flex items-center gap-2 transition-opacity duration-150 hover:opacity-70">
      <img src="/verdex-icon.png" alt="VerdeX" style="height: 28px; width: 28px; border-radius: 50%; object-fit: cover;" />
      <span class="font-bold text-lg" style="color: #1A3D2B;">VerdeX</span>
    </a>

    <!-- Nav + search + toggle -->
    <div class="flex items-center gap-1">
      <!-- Desktop nav -->
      <nav class="hidden sm:flex items-center gap-1 mr-1">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'px-3 py-2.5 rounded-lg text-sm transition-colors duration-150 min-h-[44px] inline-flex items-center',
              isActive(href)
                ? 'font-medium'
                : 'text-stone-600 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-100',
            ]}
            style={isActive(href) ? 'color: #1A3D2B;' : ''}
          >
            {label}
          </a>
        ))}
      </nav>
      <SearchModal />
      <ThemeToggle />
      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="sm:hidden inline-flex items-center justify-center w-10 h-10 rounded-lg text-stone-600 dark:text-stone-400 hover:bg-stone-200 dark:hover:bg-stone-800 transition-colors duration-150"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

  </div>

  <!-- Mobile menu dropdown -->
  <nav id="mobile-menu" class="hidden sm:hidden border-t border-stone-200 dark:border-stone-800" aria-label="Mobile navigation">
    <div class="max-w-5xl mx-auto px-4 py-2 flex flex-col">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'px-3 py-3 rounded-lg text-sm transition-colors duration-150',
            isActive(href)
              ? 'font-medium'
              : 'text-stone-600 dark:text-stone-400',
          ]}
          style={isActive(href) ? 'color: #1A3D2B;' : ''}
        >
          {label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var btn = document.getElementById('mobile-menu-btn');
    var menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;

    btn.addEventListener('click', function () {
      var isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>
