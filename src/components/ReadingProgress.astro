---
/**
 * Reading progress bar — 4px amber bar fixed at the very top of the viewport.
 * Shows percentage text that appears after scrolling begins.
 * Uses only inline styles to avoid any Tailwind/CSS conflicts.
 * Script deferred until DOM is fully parsed.
 */
---

<div
  id="reading-progress-bar"
  style="position:fixed;top:0;left:0;width:0%;height:3px;background:#2E7D32;z-index:9995;pointer-events:none;transition:width 80ms linear;transform:translateZ(0);"
></div>

<div
  id="reading-progress-pct"
  style="position:fixed;top:8px;right:16px;z-index:9995;pointer-events:none;font-size:11px;font-weight:600;color:#2E7D32;opacity:0;transition:opacity 200ms ease;font-family:var(--font-mono);background:rgba(250,250,250,0.9);padding:2px 6px;"
></div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var bar = document.getElementById('reading-progress-bar');
    var pct = document.getElementById('reading-progress-pct');
    if (!bar || !pct) return;

    var article = document.querySelector('article');
    if (!article) return;

    var ticking = false;

    function update() {
      ticking = false;
      var scrollY = window.scrollY || window.pageYOffset;
      var winHeight = window.innerHeight;

      var rect = article.getBoundingClientRect();
      var articleBottom = rect.bottom + scrollY;

      // End point: when article bottom reaches viewport bottom
      var end = articleBottom - winHeight;

      var progress;
      if (end <= 0) {
        progress = scrollY > 10 ? 1 : 0;
      } else {
        progress = scrollY / end;
        if (progress < 0) progress = 0;
        if (progress > 1) progress = 1;
      }

      bar.style.width = (progress * 100) + '%';

      if (scrollY > 100) {
        pct.style.opacity = '1';
        pct.textContent = Math.round(progress * 100) + '%';
      } else {
        pct.style.opacity = '0';
      }
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    update();
  });
</script>
