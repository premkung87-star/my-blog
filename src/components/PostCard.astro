---
import TagBadge from './TagBadge.astro';
import { formatReadingTime } from '../utils/reading-time';

interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  readingTime: number;
  postType?: string;
}

const { slug, title, description, pubDate, tags, readingTime, postType } = Astro.props;

// Terminal timestamp
const ts = pubDate.toISOString().split('T')[0].replace(/-/g, '.');
---

<article class="post-card group relative p-6 flex gap-6 items-start transition-all duration-200 cursor-pointer" style="background: var(--color-surface-low); border-left: 4px solid var(--color-border);">
  <a href={`/blog/${slug}`} class="absolute inset-0" aria-label={title}></a>

  <!-- Meta column -->
  <div class="hidden sm:flex flex-col items-center flex-shrink-0 w-16 h-16 justify-center" style="background: var(--color-primary);">
    <span class="font-mono text-[9px] tracking-widest uppercase" style="color: var(--color-bg); opacity: 0.7;">{ts.slice(5)}</span>
  </div>

  <div class="flex-grow min-w-0">
    <!-- Terminal metadata -->
    <div class="flex flex-wrap justify-between mb-2">
      <span class="font-mono text-[10px] uppercase tracking-widest" style="color: var(--color-primary); opacity: 0.5;">
        TS_{ts}
      </span>
      <span class="font-mono text-[10px] uppercase tracking-widest" style="color: var(--color-muted); opacity: 0.5;">
        {formatReadingTime(readingTime)}
        {postType && ` // ${postType.toUpperCase()}`}
      </span>
    </div>

    <!-- Title -->
    <h3 class="font-display font-bold uppercase tracking-tight text-lg leading-snug mb-2 transition-colors duration-200 group-hover:text-[#2E7D32]">
      {title}
    </h3>

    <!-- Description -->
    <p class="text-sm leading-relaxed line-clamp-2 mb-3" style="color: var(--color-muted);">
      {description}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap items-center gap-1 relative z-10">
      {tags.map((tag) => <TagBadge tag={tag} />)}
    </div>
  </div>
</article>

<style>
  .post-card:hover {
    border-left-color: var(--color-primary) !important;
    transform: translateX(4px);
  }
  @media (prefers-reduced-motion: reduce) {
    .post-card:hover { transform: none; }
  }
</style>
