---
import TagBadge from './TagBadge.astro';
import { formatReadingTime } from '../utils/reading-time';

interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  readingTime: number;
  postType?: string;
}

const { slug, title, description, pubDate, tags, readingTime, postType } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});

// Terminal-style date
const termDate = pubDate.toISOString().split('T')[0].replace(/-/g, '.');
---

<article class="post-card group relative border border-stone-200 dark:border-[#a8d3bf]/15 rounded-xl p-5 transition-all duration-300 bg-white dark:bg-[#0f3d32] hover:border-[#a8d3bf]/50 dark:hover:border-[#a8d3bf]/30" style="box-shadow: 0 4px 24px rgba(15,61,50,0.15);">
  <a href={`/blog/${slug}`} class="absolute inset-0 rounded-xl" aria-label={title}></a>

  <!-- Scan line effect on hover -->
  <div class="scan-line" aria-hidden="true"></div>

  <!-- Meta row — monospace terminal style -->
  <div class="flex items-center gap-2 mb-3 text-[11px] tracking-wide" style="font-family: var(--font-mono); color: var(--color-muted); opacity: 0.7;">
    <span style="color: #ffb700;">{termDate}</span>
    <span aria-hidden="true">//</span>
    <span>{formatReadingTime(readingTime)}</span>
    {postType && (
      <>
        <span aria-hidden="true">//</span>
        <span class="uppercase">{postType}</span>
      </>
    )}
  </div>

  <!-- Title -->
  <h2 class="text-lg font-semibold leading-snug mb-2 transition-all duration-200 text-stone-900 dark:text-stone-100 group-hover:text-[#0f3d32] dark:group-hover:text-[#a8d3bf] group-hover:[text-shadow:0_0_8px_#a8d3bf]">
    {title}
  </h2>

  <!-- Description -->
  <p class="text-stone-500 dark:text-stone-400 text-sm leading-relaxed line-clamp-2 mb-3">
    {description}
  </p>

  <!-- Tags -->
  <div class="flex flex-wrap items-center gap-1 relative z-10">
    {tags.map((tag) => <TagBadge tag={tag} />)}
  </div>
</article>

<style>
  .post-card {
    position: relative;
    overflow: hidden;
  }

  .scan-line {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, #a8d3bf, transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .post-card:hover .scan-line {
    opacity: 0.6;
    animation: scan 1.5s ease-in-out infinite;
  }

  @keyframes scan {
    0% { left: -100%; top: 0; }
    50% { left: 100%; top: 50%; }
    100% { left: -100%; top: 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .post-card:hover .scan-line {
      animation: none;
      opacity: 0;
    }
  }
</style>
