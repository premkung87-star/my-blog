---
import { siteConfig } from '../config';
const year = new Date().getFullYear();
---

<footer style="background-color: #0F3D32; color: #FAFAFA;" class="mt-16">
  <div class="max-w-7xl mx-auto px-8 pt-16 pb-12">

    <!-- Newsletter section -->
    <div class="mb-16 pb-12" style="border-bottom: 1px solid rgba(168,211,191,0.1);">
      <div class="max-w-2xl mx-auto text-center space-y-6">
        <span class="font-display text-[10px] tracking-[0.4em] uppercase" style="color: #2E7D32;">SYSTEM_CONNECTION</span>
        <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tighter uppercase leading-tight">
          REQUEST_ACCESS_TO<br/>THE_INNER_LOOP
        </h2>
        <p class="text-sm" style="color: rgba(168,211,191,0.7);">
          บทความใหม่ตรงถึง inbox — no noise, just signal.
        </p>
        <form
          action={siteConfig.buttondown.action}
          method="post"
          class="flex flex-col sm:flex-row items-end gap-4 pt-4 max-w-lg mx-auto"
        >
          <div class="flex-grow w-full text-left">
            <label for="bd-email-footer" class="font-display text-[10px] tracking-widest uppercase block mb-2" style="color: rgba(250,250,250,0.5);">
              USER_IDENTIFICATION (EMAIL)
            </label>
            <div class="flex items-center font-display text-lg" style="border-bottom: 2px solid #2E7D32; padding: 8px 0;">
              <span class="mr-3" style="color: #2E7D32;">&gt;</span>
              <input
                type="email"
                name="email"
                id="bd-email-footer"
                required
                placeholder="YOU@TERMINAL.IO"
                class="bg-transparent border-none p-0 text-white w-full placeholder:opacity-20 focus:ring-0 focus:outline-none"
                style="font-family: var(--font-display); font-size: 14px; letter-spacing: 0.05em;"
              />
            </div>
          </div>
          <button
            type="submit"
            class="w-full sm:w-auto px-8 py-3 font-display font-bold uppercase tracking-widest text-xs transition-all duration-200 hover:opacity-90"
            style="background-color: #2E7D32; color: #0F3D32;"
          >
            SUBMIT
          </button>
        </form>
      </div>
    </div>

    <!-- Footer grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">

      <div class="space-y-4">
        <h4 class="font-display text-[11px] tracking-[0.25em] font-bold uppercase" style="color: #2E7D32;">SYSTEM_MANIFESTO</h4>
        <p class="text-xs leading-relaxed" style="color: rgba(168,211,191,0.5);">
          VerdeX is an experimental node — synthesizing analog wisdom with digital precision.
          Smart farming powered by AI, rooted in Chiang Mai.
        </p>
      </div>

      <div class="space-y-4">
        <h4 class="font-display text-[11px] tracking-[0.25em] font-bold uppercase" style="color: #2E7D32;">NAVIGATION</h4>
        <ul class="font-display text-[10px] tracking-widest uppercase space-y-3">
          {[
            { href: '/blog', label: 'ARCHIVE' },
            { href: '/rss.xml', label: 'RSS_FEED' },
            { href: '/books', label: 'BOOKSHELF' },
            { href: '/sitemap-index.xml', label: 'SITEMAP' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="footer-nav-link transition-all duration-200" style="color: rgba(250,250,250,0.35);">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="space-y-4">
        <h4 class="font-display text-[11px] tracking-[0.25em] font-bold uppercase" style="color: #2E7D32;">SYSTEM_STATS</h4>
        <div class="font-mono text-[10px] tracking-widest uppercase space-y-2" style="color: rgba(168,211,191,0.35);">
          <div class="flex justify-between"><span>UPTIME</span><span>99.9%</span></div>
          <div class="flex justify-between"><span>STACK</span><span>ASTRO_4</span></div>
          <div class="flex justify-between"><span>DEPLOY</span><span>VERCEL</span></div>
          <div class="flex justify-between"><span>KERNEL</span><span>v1.0</span></div>
        </div>
      </div>

      <div class="space-y-4">
        <h4 class="font-display text-[11px] tracking-[0.25em] font-bold uppercase" style="color: #2E7D32;">ESTABLISH_LINK</h4>
        <p class="text-xs leading-relaxed" style="color: rgba(168,211,191,0.5);">
          Transmit inquiries directly to the primary node.
        </p>
        <a href="/contact" class="font-display text-[10px] tracking-widest uppercase underline underline-offset-4" style="color: #2E7D32;">
          CONTACT_FORM
        </a>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 pt-8" style="border-top: 1px solid rgba(168,211,191,0.1);">
      <span class="font-display text-[10px] tracking-widest uppercase" style="color: rgba(250,250,250,0.3);">
        &copy; {year} VERDEX // SYSTEM_ID: TERMINAL_01
      </span>
      <div class="flex gap-6">
        <span class="font-mono text-[10px] uppercase tracking-widest" style="color: rgba(46,125,50,0.4);">STATUS: NOMINAL</span>
        <span class="font-mono text-[10px] uppercase tracking-widest" style="color: #2E7D32;">LOC: CHIANG_MAI</span>
      </div>
    </div>

  </div>
</footer>

<style>
  .footer-nav-link:hover {
    color: #A8D3BF !important;
  }
  .footer-nav-link:hover::before {
    content: '> ';
  }
</style>
