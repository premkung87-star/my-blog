---
const year = new Date().getFullYear();
---

<footer class="border-t border-stone-200 dark:border-stone-800 mt-16">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8 text-sm text-stone-400 dark:text-stone-500">

    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">

      <!-- Left: identity -->
      <div>
        <p class="font-medium text-stone-500 dark:text-stone-400 mb-1">VerdeX</p>
        <p class="text-xs leading-relaxed max-w-xs">
          Smart greenhouse farm for growing Sweet Basil, powered by AI.
          Based in Chiang Mai, Thailand.
        </p>
      </div>

      <!-- Right: links -->
      <div class="flex flex-col items-start sm:items-end gap-3">
        <!-- Site links -->
        <nav class="flex items-center gap-3 flex-wrap" aria-label="Site links">
          <a href="/blog" class="hover:text-stone-700 dark:hover:text-stone-300 transition-colors duration-150 py-2 inline-block">
            Blog
          </a>
          <a href="/categories" class="hover:text-stone-700 dark:hover:text-stone-300 transition-colors duration-150 py-2 inline-block">
            Categories
          </a>
          <a href="/about" class="hover:text-stone-700 dark:hover:text-stone-300 transition-colors duration-150 py-2 inline-block">
            About
          </a>
          <a href="/contact" class="hover:text-stone-700 dark:hover:text-stone-300 transition-colors duration-150 py-2 inline-block">
            Contact
          </a>
          <a href="/sitemap-index.xml" class="hover:text-stone-700 dark:hover:text-stone-300 transition-colors duration-150 py-2 inline-block">
            Sitemap
          </a>
        </nav>
      </div>

    </div>

    <p class="mt-6 text-xs">&copy; {year} VerdeX · Chiang Mai, Thailand</p>

  </div>
</footer>
