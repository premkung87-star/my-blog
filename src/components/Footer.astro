---
import { siteConfig } from '../config';
const year = new Date().getFullYear();
---

<footer class="mt-16" style="border-top: 1px solid var(--color-accent); opacity: 1;">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10 text-sm" style="font-family: var(--font-mono);">

    <!-- Newsletter -->
    <div class="mb-8 pb-8" style="border-bottom: 1px solid var(--color-border);">
      <p class="text-[11px] mb-3" style="color: var(--color-muted); opacity: 0.5;">// subscribe</p>
      <p class="font-medium mb-1" style="color: var(--color-accent);">VerdeX Notes</p>
      <p class="text-xs mb-4" style="color: var(--color-muted);">
        บทความใหม่ตรงถึง inbox — no spam, unsubscribe anytime.
      </p>
      <form
        action={siteConfig.buttondown.action}
        method="post"
        class="flex flex-col sm:flex-row gap-2 max-w-md"
      >
        <label for="bd-email-footer" class="sr-only">Email</label>
        <input
          type="email"
          name="email"
          id="bd-email-footer"
          required
          placeholder="you@example.com"
          class="flex-1 px-3 py-2 rounded border text-sm min-h-[44px] bg-white dark:bg-[#111111] text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-stone-500 focus:outline-none focus:ring-1"
          style="border-color: var(--color-border); font-family: var(--font-mono); font-size: 13px;"
        />
        <button
          type="submit"
          class="px-5 py-2 rounded text-sm font-medium transition-all duration-200 hover:opacity-90 min-h-[44px] bg-[#1A3D2B] dark:bg-[#8BBFAA] text-white dark:text-[#0A0A0A]"
          style="font-family: var(--font-mono);"
        >
          subscribe
        </button>
      </form>
    </div>

    <!-- Links grid -->
    <div class="flex flex-col sm:flex-row items-start justify-between gap-8 mb-8">

      <!-- Left: identity -->
      <div>
        <p class="text-[11px] mb-3" style="color: var(--color-muted); opacity: 0.5;">// about</p>
        <p class="font-medium mb-1" style="color: var(--color-accent);">VerdeX</p>
        <p class="text-xs leading-relaxed max-w-xs" style="color: var(--color-muted);">
          Smart greenhouse farm for Sweet Basil,<br/>
          powered by AI · Chiang Mai, Thailand
        </p>
      </div>

      <!-- Right: nav links -->
      <div>
        <p class="text-[11px] mb-3" style="color: var(--color-muted); opacity: 0.5;">// navigate</p>
        <nav class="flex flex-col gap-1" aria-label="Footer navigation">
          {[
            { href: '/blog', label: 'blog' },
            { href: '/books', label: 'books' },
            { href: '/categories', label: 'categories' },
            { href: '/about', label: 'about' },
            { href: '/contact', label: 'contact' },
            { href: '/rss.xml', label: 'rss' },
          ].map(({ href, label }) => (
            <a
              href={href}
              class="text-xs transition-colors duration-150 py-0.5 hover:text-[#1A3D2B] dark:hover:text-[#8BBFAA]"
              style="color: var(--color-muted);"
            >
              ./{label}
            </a>
          ))}
        </nav>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="pt-4 flex items-center justify-between" style="border-top: 1px solid var(--color-border);">
      <p class="text-[11px]" style="color: var(--color-muted); opacity: 0.4;">
        &copy; {year} VerdeX · Chiang Mai
      </p>
      <p class="text-[11px]" style="color: var(--color-muted); opacity: 0.3;">
        v1.0 — built with astro
      </p>
    </div>

  </div>
</footer>
