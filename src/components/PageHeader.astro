---
interface Props {
  title: string;
  breadcrumb?: string;
  description?: string;
}

const { title, breadcrumb, description } = Astro.props;
---

<div class="mb-10">
  {breadcrumb && (
    <p class="text-[11px] mb-4" style="font-family: var(--font-mono); color: var(--color-muted); opacity: 0.5;">
      // {breadcrumb}
    </p>
  )}
  <h1 class="text-3xl font-bold text-stone-900 dark:text-stone-50 mb-2">{title}</h1>
  {description && (
    <p class="text-stone-500 dark:text-stone-400">{description}</p>
  )}

  <!-- Y2K dots separator -->
  <div class="flex items-center gap-0 mt-5 select-none" aria-hidden="true">
    <span class="inline-block w-[3px] h-[3px] rounded-full mx-[3px]" style="background-color: var(--color-accent); opacity: 0.3;"></span>
    <span class="inline-block w-[3px] h-[3px] rounded-full mx-[3px]" style="background-color: var(--color-accent); opacity: 0.3;"></span>
    <span class="inline-block w-[3px] h-[3px] rounded-full mx-[3px]" style="background-color: var(--color-accent); opacity: 0.3;"></span>
    <span class="inline-block w-[28px] h-[1px] mx-[3px]" style="background-color: var(--color-accent); opacity: 0.3; vertical-align: middle;"></span>
    <span class="inline-block w-[3px] h-[3px] rounded-full mx-[3px]" style="background-color: var(--color-accent); opacity: 0.3;"></span>
    <span class="inline-block w-[3px] h-[3px] rounded-full mx-[3px]" style="background-color: var(--color-accent); opacity: 0.3;"></span>
    <span class="inline-block w-[3px] h-[3px] rounded-full mx-[3px]" style="background-color: var(--color-accent); opacity: 0.3;"></span>
  </div>
</div>
