---
const currentPath = Astro.url.pathname;

const items = [
  { href: '/',     label: 'Home',   icon: 'home' },
  { href: '/blog', label: 'Blog',   icon: 'blog' },
  { href: '/books',label: 'Books',  icon: 'books' },
  { href: '/about',label: 'About',  icon: 'about' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<nav class="mobile-bottom-nav sm:hidden" aria-label="Mobile navigation">
  {items.map(({ href, label, icon }) => (
    <a
      href={href}
      class:list={[
        'mobile-nav-item',
        isActive(href) ? 'active' : '',
      ]}
    >
      {icon === 'home' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
      )}
      {icon === 'blog' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
        </svg>
      )}
      {icon === 'books' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
        </svg>
      )}
      {icon === 'about' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
      )}
      <span class="text-[10px] mt-0.5">{label}</span>
    </a>
  ))}
</nav>

<style>
  .mobile-bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 90;
    display: flex;
    justify-content: space-around;
    align-items: center;
    height: 56px;
    background-color: rgba(245, 245, 240, 0.95);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }

  :global(.dark) .mobile-bottom-nav {
    background-color: rgba(12, 10, 9, 0.95);
    border-top-color: rgba(255, 255, 255, 0.08);
  }

  .mobile-nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 1;
    height: 100%;
    color: #78716c;
    text-decoration: none;
    transition: color 0.15s ease;
    -webkit-tap-highlight-color: transparent;
  }

  :global(.dark) .mobile-nav-item {
    color: #78716c;
  }

  .mobile-nav-item.active {
    color: #1A3D2B;
  }

  :global(.dark) .mobile-nav-item.active {
    color: #8BBFAA;
  }

  /* Hide on desktop */
  @media (min-width: 640px) {
    .mobile-bottom-nav {
      display: none !important;
    }
  }
</style>
