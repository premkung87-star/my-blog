---
interface SeriesPost {
  slug: string;
  title: string;
  order: number;
}

interface Props {
  seriesName: string;
  currentSlug: string;
  posts: SeriesPost[];
}

const { seriesName, currentSlug, posts } = Astro.props;
const sorted = [...posts].sort((a, b) => a.order - b.order);
const currentIndex = sorted.findIndex((p) => p.slug === currentSlug);
const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const next = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
---

<nav class="mt-10 p-5 rounded-xl border border-stone-200 dark:border-stone-800 bg-stone-50 dark:bg-stone-900" aria-label="Series navigation">
  <p class="text-xs font-semibold uppercase tracking-widest text-stone-400 dark:text-stone-500 mb-3">
    Series: {seriesName} — Part {currentIndex + 1} of {sorted.length}
  </p>

  <div class="flex flex-col sm:flex-row gap-3 sm:justify-between">
    {prev ? (
      <a href={`/blog/${prev.slug}/`} class="flex items-center gap-2 text-sm text-stone-600 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-100 transition-colors">
        <span aria-hidden="true">&larr;</span>
        <span class="line-clamp-1">{prev.title}</span>
      </a>
    ) : <span />}

    {next ? (
      <a href={`/blog/${next.slug}/`} class="flex items-center gap-2 text-sm text-stone-600 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-100 transition-colors sm:text-right">
        <span class="line-clamp-1">{next.title}</span>
        <span aria-hidden="true">&rarr;</span>
      </a>
    ) : <span />}
  </div>
</nav>
