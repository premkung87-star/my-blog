---
interface RelatedPost {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  postType?: string;
}

interface Props {
  posts: RelatedPost[];
}

const { posts } = Astro.props;
---

<section class="mt-12 pt-8 border-t border-stone-200 dark:border-stone-800">
  <h2 class="text-xs font-semibold uppercase tracking-widest text-stone-400 dark:text-stone-500 mb-4">
    Related Posts
  </h2>
  <div class="grid gap-4 sm:grid-cols-2">
    {posts.map((post) => {
      const formattedDate = post.pubDate.toLocaleDateString('en-GB', {
        day: 'numeric',
        month: 'short',
        year: 'numeric',
      });
      return (
        <a
          href={`/blog/${post.slug}`}
          class="group block rounded-xl border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900 p-5 hover:border-amber-300 dark:hover:border-amber-700 transition-all duration-200 hover:shadow-md hover:shadow-amber-100/50 dark:hover:shadow-amber-900/20"
        >
          <div class="flex items-center gap-2 mb-2">
            {post.postType && (
              <span class="post-type-badge text-[10px] px-1.5 py-0.5">{post.postType}</span>
            )}
            <time class="text-xs text-stone-400 dark:text-stone-500" datetime={post.pubDate.toISOString()}>
              {formattedDate}
            </time>
          </div>
          <h3 class="text-sm font-semibold text-stone-900 dark:text-stone-50 group-hover:text-amber-700 dark:group-hover:text-amber-400 transition-colors duration-150 leading-snug mb-1">
            {post.title}
          </h3>
          <p class="text-xs text-stone-500 dark:text-stone-400 leading-relaxed line-clamp-2">
            {post.description}
          </p>
        </a>
      );
    })}
  </div>
</section>
