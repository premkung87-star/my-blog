---
import BaseLayout from './BaseLayout.astro';
import TagBadge from '../components/TagBadge.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ShareButtons from '../components/ShareButtons.astro';
import Newsletter from '../components/Newsletter.astro';
import SeriesNav from '../components/SeriesNav.astro';
import Giscus from '../components/Giscus.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import { formatReadingTime } from '../utils/reading-time';

interface RelatedPost {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  postType?: string;
}

interface SeriesPost {
  slug: string;
  title: string;
  order: number;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  readingTime: number;
  lang?: 'en' | 'th';
  postType?: string;
  relatedPosts?: RelatedPost[];
  series?: string;
  seriesSlug?: string;
  seriesPosts?: SeriesPost[];
  ogImage?: string;
}

const { title, description, pubDate, tags, readingTime, lang = 'en', postType, relatedPosts = [], series, seriesSlug, seriesPosts = [], ogImage } = Astro.props;

// ToC shown only for posts > 5 min reading time
const showToC = readingTime > 5;

const ts = pubDate.toISOString().split('T')[0].replace(/-/g, '.');
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  ogType="article"
  pubDate={pubDate}
  tags={tags}
  ogImage={ogImage}
>
  <div class="pt-20 w-full max-w-5xl mx-auto px-6 py-12 md:py-24">

    <!-- ═══ TERMINAL HEADER — Article metadata ═══ -->
    <section class="mb-16 p-8 relative" style="background: var(--color-surface-low); border-left: 4px solid var(--color-primary);">
      <!-- System metadata -->
      <div class="font-mono text-[10px] uppercase tracking-widest mb-4 flex flex-wrap gap-4" style="color: var(--color-subtle);">
        <span>[FILE_ID: {Math.random().toString(36).slice(2, 6).toUpperCase()}]</span>
        {postType && <span>[SECTOR: {postType.toUpperCase()}]</span>}
        <span>[STATUS: READ_ONLY]</span>
      </div>

      <!-- Title with blinking cursor -->
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-bold leading-tight mb-6" style="color: var(--color-primary);">
        {title}<span class="blink-cursor"></span>
      </h1>

      <!-- Description -->
      <p class="text-lg leading-relaxed mb-8" style="color: var(--color-muted);">
        {description}
      </p>

      <!-- Author / Date / Reading time grid -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 pt-6 font-display text-xs uppercase tracking-tight" style="border-top: 1px solid var(--color-border);">
        <div>
          <p style="color: var(--color-subtle);">AUTHOR</p>
          <p class="font-bold" style="color: var(--color-primary);">PREM</p>
        </div>
        <div>
          <p style="color: var(--color-subtle);">TIMESTAMP</p>
          <p class="font-bold" style="color: var(--color-primary);">{ts} // UTC</p>
        </div>
        <div>
          <p style="color: var(--color-subtle);">READ_TIME</p>
          <p class="font-bold" style="color: var(--color-primary);">{formatReadingTime(readingTime).toUpperCase().replace(' ', '_')}</p>
        </div>
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap items-center gap-1.5 mt-6">
        {tags.map((tag) => <TagBadge tag={tag} />)}
      </div>
    </section>

    <!-- ═══ ARTICLE CONTENT ═══ -->
    <div class:list={[
      showToC ? 'flex flex-col xl:flex-row xl:gap-16 xl:items-start' : '',
    ]}>

      <article class="min-w-0 flex-1 max-w-2xl" data-pagefind-body>

        <!-- Mobile ToC -->
        {showToC && (
          <details class="xl:hidden mb-8 overflow-hidden group ghost-border">
            <summary class="flex items-center justify-between gap-3 px-4 py-3 cursor-pointer list-none select-none text-sm font-display font-medium transition-colors duration-150" style="color: var(--color-primary); background: var(--color-surface-low);">
              <span class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" style="color: #2E7D32;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h10M4 18h7"/>
                </svg>
                CONTENTS
              </span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-200 group-open:rotate-180" style="color: var(--color-subtle);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <nav aria-label="Table of contents" class="px-4 pb-4 pt-1" style="background: var(--color-surface-low);">
              <ul id="toc-mobile-list" class="space-y-0.5 text-sm">
                <li class="text-xs italic" style="color: var(--color-subtle);">Loading…</li>
              </ul>
            </nav>
          </details>
        )}

        <!-- Post body -->
        <div class="prose-content">
          <slot />
        </div>

        <!-- Share buttons -->
        <ShareButtons title={title} />

        <!-- Series navigation -->
        {series && seriesSlug && seriesPosts.length > 1 && (
          <SeriesNav seriesName={series} currentSlug={seriesSlug} posts={seriesPosts} />
        )}

        <!-- Newsletter -->
        <Newsletter />

        <!-- Related posts -->
        {relatedPosts.length > 0 && <RelatedPosts posts={relatedPosts} />}

        <!-- Footer nav -->
        <footer class="mt-12 pt-8" style="border-top: 1px solid var(--color-border);">
          <div class="flex gap-4">
            <a
              href="/blog"
              class="px-6 py-3 font-display text-xs uppercase tracking-widest transition-all duration-200 phosphor-glow"
              style="background: var(--color-primary); color: var(--color-bg);"
            >
              EXECUTE_BACK
            </a>
            <a
              href="/"
              class="px-6 py-3 font-display text-xs uppercase tracking-widest transition-all duration-200"
              style="border: 1px solid var(--color-border); color: var(--color-primary);"
            >
              ROOT_HOME_
            </a>
          </div>
        </footer>

        <!-- Comments -->
        <Giscus />

      </article>

      <!-- Desktop ToC sidebar -->
      {showToC && <TableOfContents />}

    </div>
  </div>
</BaseLayout>
