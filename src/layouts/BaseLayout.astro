---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import Lightbox from '../components/Lightbox.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import LoadingSkeleton from '../components/LoadingSkeleton.astro';
import ErrorReporter from '../components/ErrorReporter.astro';
import MobileBottomNav from '../components/MobileBottomNav.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'th';
  canonicalURL?: string;
  ogType?: 'website' | 'article';
  pubDate?: Date;
  ogImage?: string;
  tags?: string[];
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = 'Solo entrepreneur in Chiang Mai building VerdeX Farm — a smart hydroponic system for commercial herb growers. Writing about entrepreneurship, technology, and building in public.',
  lang = 'en',
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  ogType = 'website',
  pubDate,
  ogImage,
  tags = [],
  jsonLd,
} = Astro.props;

const siteName = "VerdeX";
const siteUrl = 'https://my-blog-kohl-one.vercel.app';
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
const ogLocale = lang === 'th' ? 'th_TH' : 'en_US';

// Build Article JSON-LD automatically for blog posts
const articleJsonLd = ogType === 'article' && pubDate ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: pubDate.toISOString(),
  inLanguage: lang === 'th' ? 'th' : 'en',
  url: canonicalURL,
  author: {
    '@type': 'Person',
    name: 'Prem',
    url: `${siteUrl}/about`,
  },
  publisher: {
    '@type': 'Organization',
    name: siteName,
    url: siteUrl,
  },
} : null;

const finalJsonLd = jsonLd || articleJsonLd;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#fafaf9" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0c0a09" media="(prefers-color-scheme: dark)" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" type="application/rss+xml" title="VerdeX RSS Feed" href="/rss.xml" />
    <ViewTransitions />

    <!-- Plausible Analytics -->
    <script defer data-domain="my-blog-kohl-one.vercel.app" src="https://plausible.io/js/script.js"></script>

    <!-- hreflang -->
    <link rel="alternate" hreflang={lang} href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:type"        content={ogType} />
    <meta property="og:locale"           content={ogLocale} />
    <meta property="og:locale:alternate" content={lang === 'th' ? 'en_US' : 'th_TH'} />
    <meta property="og:site_name"        content={siteName} />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).href} />}
    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {ogType === 'article' && <meta property="article:author" content={`${siteUrl}/about`} />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter / X Card -->
    <meta name="twitter:card"        content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:site"        content="@premkung" />
    {ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />}

    <!-- Structured data -->
    {finalJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(finalJsonLd)} />
    )}

    <!-- Thai + Latin font: Sarabun from Google Fonts (subset: latin + thai) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Sarabun:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&subset=latin,thai&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Sarabun:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&subset=latin,thai&family=Lora:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <!--
      Theme init: runs before first paint to prevent flash of wrong theme.
      Reads localStorage → falls back to OS preference.
    -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var dark = stored === 'dark' || (!stored && prefersDark);
        if (dark) document.documentElement.classList.add('dark');
      })();
    </script>
    <slot name="head" />
  </head>

  <body class="bg-[#F5F5F0] text-stone-800 dark:bg-stone-950 dark:text-stone-100 transition-colors duration-200 min-h-screen flex flex-col font-sans">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[70] focus:px-4 focus:py-2 focus:bg-amber-600 focus:text-white focus:rounded-lg focus:text-sm focus:font-medium">
      Skip to content
    </a>
    {ogType === 'article' && <ReadingProgress />}
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <MobileBottomNav />
    <div class="h-14 sm:hidden" aria-hidden="true"></div>
    <Lightbox />
    <ScrollToTop />
    <LoadingSkeleton />
    <ErrorReporter />
  </body>
</html>
