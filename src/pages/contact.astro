---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Prem — questions, collaboration ideas, or just a friendly hello."
  jsonLd={{ '@context': 'https://schema.org', '@type': 'ContactPage', name: 'Contact', url: `${siteConfig.url}/contact` }}
>
  <div class="pt-20 max-w-3xl mx-auto px-6 py-12 md:py-24 text-center">

    <!-- Title -->
    <div class="font-mono text-[10px] tracking-widest uppercase mb-4" style="color: var(--color-subtle);">
      [SYS_MSG]: HAVE A QUESTION, IDEA, OR JUST WANT TO SAY HI?
    </div>
    <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold tracking-tighter uppercase leading-none mb-12" style="color: var(--color-primary);">
      GET_IN_TOUCH<span class="blink-cursor"></span>
    </h1>

    <!-- Terminal window form -->
    <div class="terminal-window text-left max-w-lg mx-auto">
      <div class="terminal-header">
        <span>COMMUNICATION_PROTOCOL_V2.0</span>
        <div class="terminal-dots">
          <span></span><span></span><span></span>
        </div>
      </div>
      <div class="terminal-body">
        <form
          id="contact-form"
          action={siteConfig.formspree.action}
          method="POST"
          class="space-y-6"
        >
          <!-- Username -->
          <div>
            <label for="name" class="font-mono text-[10px] tracking-widest uppercase block mb-2" style="color: var(--color-subtle);">
              &gt;USERNAME
            </label>
            <input
              type="text" id="name" name="name" required autocomplete="name"
              placeholder="Identify yourself"
              class="w-full bg-transparent py-2 text-sm focus:outline-none placeholder:opacity-30"
              style="border: none; border-bottom: 2px solid var(--color-primary); color: var(--color-text); font-family: var(--font-body);"
            />
          </div>

          <!-- Uplink address -->
          <div>
            <label for="email" class="font-mono text-[10px] tracking-widest uppercase block mb-2" style="color: var(--color-subtle);">
              &gt;UPLINK_ADDR
            </label>
            <input
              type="email" id="email" name="email" required autocomplete="email"
              placeholder="you@network.com"
              class="w-full bg-transparent py-2 text-sm focus:outline-none placeholder:opacity-30"
              style="border: none; border-bottom: 2px solid var(--color-primary); color: var(--color-text); font-family: var(--font-body);"
            />
          </div>

          <!-- Subject -->
          <div>
            <label for="subject" class="font-mono text-[10px] tracking-widest uppercase block mb-2" style="color: var(--color-subtle);">
              &gt;SUBJECT (OPTIONAL)
            </label>
            <input
              type="text" id="subject" name="subject"
              placeholder="Nature of inquiry"
              class="w-full bg-transparent py-2 text-sm focus:outline-none placeholder:opacity-30"
              style="border: none; border-bottom: 2px solid var(--color-primary); color: var(--color-text); font-family: var(--font-body);"
            />
          </div>

          <!-- Data stream -->
          <div>
            <label for="message" class="font-mono text-[10px] tracking-widest uppercase block mb-2" style="color: var(--color-subtle);">
              &gt;DATA_STREAM
            </label>
            <textarea
              id="message" name="message" required rows="4"
              placeholder="Transmit your message here..."
              class="w-full bg-transparent py-2 text-sm focus:outline-none placeholder:opacity-30 resize-y min-h-[100px]"
              style="border: none; border-bottom: 2px solid var(--color-primary); color: var(--color-text); font-family: var(--font-body);"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full py-4 font-display font-bold uppercase tracking-widest text-sm transition-all duration-200 phosphor-glow"
            style="background-color: #2E7D32; color: #0F3D32;"
          >
            EXECUTE_TRANSMIT
          </button>
        </form>
      </div>
    </div>

    <!-- Status messages -->
    <div id="form-success" class="hidden mt-8 p-6 text-left" style="background: var(--color-surface-low); border-left: 4px solid #2E7D32;">
      <p class="font-display font-bold uppercase tracking-widest text-sm" style="color: #2E7D32;">TRANSMISSION_SUCCESSFUL</p>
      <p class="text-sm mt-2" style="color: var(--color-muted);">Message received. Response incoming.</p>
    </div>

    <div id="form-error" class="hidden mt-8 p-6 text-left" style="background: var(--color-surface-low); border-left: 4px solid #ba1a1a;">
      <p class="font-display font-bold uppercase tracking-widest text-sm" style="color: #ba1a1a;">TRANSMISSION_FAILED</p>
      <p class="text-sm mt-2" style="color: var(--color-muted);">Error in data stream. Please retry.</p>
    </div>

  </div>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var form = document.getElementById('contact-form');
    if (!form) return;
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var btn = form.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'TRANSMITTING...';

      fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      })
        .then(function (res) {
          if (res.ok) {
            form.closest('.terminal-window').classList.add('hidden');
            document.getElementById('form-success').classList.remove('hidden');
          } else { throw new Error('Failed'); }
        })
        .catch(function () {
          document.getElementById('form-error').classList.remove('hidden');
          btn.disabled = false;
          btn.textContent = 'EXECUTE_TRANSMIT';
        });
    });
  });
</script>
