---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Prem — questions, collaboration ideas, or just a friendly hello."
  jsonLd={{ '@context': 'https://schema.org', '@type': 'ContactPage', name: 'Contact', url: `${siteConfig.url}/contact` }}
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-12">

    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-stone-900 dark:text-stone-50 mb-2">Contact</h1>
      <p class="text-stone-500 dark:text-stone-400 leading-relaxed">
        Have a question, idea, or just want to say hi? Drop me a message below and I'll get back to you.
      </p>
    </div>

    <!-- Contact form -->
    <form
      id="contact-form"
      action={siteConfig.formspree.action}
      method="POST"
      class="space-y-6"
    >
      <!-- Name -->
      <div>
        <label for="name" class="block text-sm font-medium text-stone-700 dark:text-stone-300 mb-1.5">
          Name
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          autocomplete="name"
          placeholder="Your name"
          class="w-full rounded-lg border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-4 py-2.5 text-stone-900 dark:text-stone-100 placeholder:text-stone-400 dark:placeholder:text-stone-600 focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 outline-none transition-colors duration-150"
        />
      </div>

      <!-- Email -->
      <div>
        <label for="email" class="block text-sm font-medium text-stone-700 dark:text-stone-300 mb-1.5">
          Email
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          placeholder="you@example.com"
          class="w-full rounded-lg border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-4 py-2.5 text-stone-900 dark:text-stone-100 placeholder:text-stone-400 dark:placeholder:text-stone-600 focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 outline-none transition-colors duration-150"
        />
      </div>

      <!-- Message -->
      <div>
        <label for="message" class="block text-sm font-medium text-stone-700 dark:text-stone-300 mb-1.5">
          Message
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows="5"
          placeholder="What's on your mind?"
          class="w-full rounded-lg border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-4 py-2.5 text-stone-900 dark:text-stone-100 placeholder:text-stone-400 dark:placeholder:text-stone-600 focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 outline-none transition-colors duration-150 resize-y min-h-[120px]"
        ></textarea>
      </div>

      <!-- Submit -->
      <button
        type="submit"
        class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg bg-amber-600 hover:bg-amber-700 text-white font-medium text-sm transition-colors duration-150 focus:ring-2 focus:ring-amber-500/20 focus:ring-offset-2 focus:ring-offset-stone-50 dark:focus:ring-offset-stone-950"
      >
        Send message
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </button>
    </form>

    <!-- Success message (hidden by default) -->
    <div id="form-success" class="hidden mt-8 p-6 rounded-xl bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800">
      <div class="flex items-start gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-600 dark:text-green-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <p class="font-medium text-green-800 dark:text-green-200">Message sent!</p>
          <p class="text-sm text-green-700 dark:text-green-300 mt-1">Thanks for reaching out. I'll get back to you soon.</p>
        </div>
      </div>
    </div>

    <!-- Error message (hidden by default) -->
    <div id="form-error" class="hidden mt-8 p-6 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800">
      <div class="flex items-start gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-600 dark:text-red-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <p class="font-medium text-red-800 dark:text-red-200">Something went wrong</p>
          <p class="text-sm text-red-700 dark:text-red-300 mt-1">Please try again, or reach out via social media.</p>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>

<script is:inline>
  var form = document.getElementById('contact-form');
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var btn = form.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = 'Sending…';

    fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { Accept: 'application/json' },
    })
      .then(function (res) {
        if (res.ok) {
          form.classList.add('hidden');
          document.getElementById('form-success').classList.remove('hidden');
        } else {
          throw new Error('Form submission failed');
        }
      })
      .catch(function () {
        document.getElementById('form-error').classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = 'Send message';
      });
  });
</script>
