---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: siteConfig.author,
  url: `${siteConfig.url}/about`,
  jobTitle: 'Solo Entrepreneur',
  description: 'Building VerdeX Farm — a smart hydroponic system for commercial herb growers. Writing about entrepreneurship, hydroponics, and technology.',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Chiang Mai',
    addressCountry: 'TH',
  },
};
---

<BaseLayout
  title="About"
  description="I'm Prem — a solo entrepreneur in Chiang Mai, Thailand, building VerdeX Farm and writing about the journey."
  jsonLd={personJsonLd}
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-12">

    <!-- Header -->
    <div class="mb-10">
      <div class="flex items-start gap-4 mb-6">
        <div class="flex-shrink-0">
          <img src="/verdex-icon.png" alt="VerdeX" style="width: 64px; height: 64px; border-radius: 50%;" />
        </div>
        <div>
          <h1 class="text-3xl font-bold text-stone-900 dark:text-stone-50 mb-1">เปรม / Prem</h1>
          <p class="text-stone-500 dark:text-stone-400">Solo Entrepreneur · Chiang Mai, Thailand</p>
        </div>
      </div>
    </div>

    <!-- Bio content -->
    <div class="prose-content">
      <p lang="th">
        สวัสดีครับ ผมชื่อเปรม กำลังสร้าง VerdeX —
        ฟาร์ม Sweet Basil อัจฉริยะที่ควบคุมด้วย AI
        ผ่าน Sensor ต่างๆ เพื่อให้ฟาร์มดูแลตัวเองได้
        ตั้งอยู่ที่เชียงใหม่ ประเทศไทย
      </p>

      <p>
        Hi, I'm Prem. I'm building VerdeX — a smart
        Sweet Basil farm powered by AI, using sensors
        to automate farm management.
        Based in Chiang Mai, Thailand.
      </p>

      <h2>Why I write</h2>

      <p lang="th">
        ผมเชื่อในสิ่งพื้นฐานสองอย่างที่ทำให้คนเก่งขึ้น
        คือ การอ่าน และ การเขียน
      </p>

      <p lang="th">
        การอ่านเปิดโลกให้คุณพบความรู้ใหม่ๆ
        การเขียนบันทึกและตกผลึกความรู้นั้น
        และเมื่อเราเชื่อว่าสิ่งที่เขียนมีประโยชน์
        เราก็อยากส่งต่อให้คนอื่น
      </p>

      <p lang="th">
        นั่นคือเหตุผลที่ผมเขียน
      </p>

      <p>
        I believe in two fundamentals that make
        people better: reading and writing.
      </p>

      <p>
        Reading opens you to new knowledge.
        Writing records and crystallizes it.
        And when you believe what you've written
        has value — you want to share it.
      </p>

      <p>
        That's why I write.
      </p>

      <h2>Get in touch</h2>

      <p>
        <a href="/contact">Send me a message</a> or find me on the links in the footer.
      </p>
    </div>

  </div>
</BaseLayout>
