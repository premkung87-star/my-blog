---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../config';
import PostCard from '../../components/PostCard.astro';
import TagBadge from '../../components/TagBadge.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../../utils/reading-time';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))].sort();

const byYear: Record<number, typeof allPosts> = {};
for (const post of allPosts) {
  const y = post.data.pubDate.getFullYear();
  if (!byYear[y]) byYear[y] = [];
  byYear[y].push(post);
}
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);
---

<BaseLayout
  title="Blog"
  description="All writing on entrepreneurship, hydroponics, and technology."
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Blog',
    description: 'All writing on entrepreneurship, hydroponics, and technology.',
    url: `${siteConfig.url}/blog`,
    isPartOf: { '@type': 'WebSite', name: siteConfig.name, url: siteConfig.url },
  }}
>
  <div class="pt-20 max-w-5xl mx-auto px-6 py-12 md:py-24">

    <!-- Terminal header -->
    <div class="font-mono text-[10px] tracking-widest uppercase mb-2" style="color: var(--color-subtle);">
      // archive / {allPosts.length}_ENTRIES_INDEXED
    </div>

    <h1 class="font-display text-4xl sm:text-5xl font-bold tracking-tighter uppercase leading-none mb-4" style="color: var(--color-primary);">
      DATA_ARCHIVE<span class="blink-cursor"></span>
    </h1>

    <p class="font-mono text-xs mb-8" style="color: var(--color-subtle);">
      // Chronological audit log. {allPosts.length} {allPosts.length === 1 ? 'entry' : 'entries'}.
    </p>

    <!-- Tag filter -->
    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-12">
        {allTags.map((tag) => <TagBadge tag={tag} />)}
      </div>
    )}

    <!-- Posts by year -->
    {years.map((year) => (
      <section class="mb-12">
        <div class="flex items-center gap-4 mb-4">
          <h2 class="font-display text-sm tracking-[0.2em] font-bold uppercase" style="color: var(--color-primary);">
            SECTOR_{year}
          </h2>
          <div class="h-px flex-grow" style="background: var(--color-border);"></div>
        </div>
        <div class="space-y-4">
          {byYear[year].map((post) => (
            <PostCard
              slug={post.slug}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              readingTime={getReadingTime(post.body)}
              postType={post.data.postType}
            />
          ))}
        </div>
      </section>
    ))}

    {allPosts.length === 0 && (
      <div class="p-8" style="background: var(--color-surface-low);">
        <p class="font-mono text-sm" style="color: var(--color-subtle);">
          NO_ENTRIES_FOUND // Write your first post to populate the archive.
        </p>
      </div>
    )}

  </div>
</BaseLayout>
