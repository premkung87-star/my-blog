---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import TagBadge from '../components/TagBadge.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../utils/reading-time';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const recentPosts = allPosts.slice(0, 3);

// Collect all unique tags across posts
const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))].sort();

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: "Prem's Notes",
  url: 'https://my-blog-kohl-one.vercel.app',
  description: 'Solo entrepreneur in Chiang Mai building VerdeX Farm — writing about entrepreneurship, hydroponics, and technology.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://my-blog-kohl-one.vercel.app/blog?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title="Prem's Notes"
  description="Solo entrepreneur in Chiang Mai building VerdeX Farm — a smart hydroponic system for commercial herb growers. Writing about entrepreneurship, technology, and building in public."
  jsonLd={websiteJsonLd}
>
  <!-- Hero -->
  <section class="max-w-2xl mx-auto px-4 sm:px-6 pt-16 pb-12">
    <div class="flex items-start gap-4 mb-6">
      <div class="w-12 h-12 rounded-full bg-amber-100 dark:bg-amber-900/40 flex items-center justify-center flex-shrink-0 mt-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-amber-600 dark:text-amber-400" viewBox="0 0 32 32" fill="currentColor">
          <path d="M16 28 C16 28 16 14 16 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>
          <path d="M16 20 C16 20 10 17 9 11 C9 11 15 11 16 20Z" opacity="0.9"/>
          <path d="M16 16 C16 16 22 12 23 6 C23 6 17 8 16 16Z"/>
        </svg>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-stone-900 dark:text-stone-50 mb-1">
          Prem's Notes
        </h1>
        <p class="text-stone-500 dark:text-stone-400 text-sm">Solo entrepreneur · Chiang Mai, Thailand</p>
      </div>
    </div>

    <p class="text-lg text-stone-700 dark:text-stone-300 leading-relaxed mb-4" lang="th">
      สวัสดีครับ ผมเปรม — entrepreneur เดี่ยวจากเชียงใหม่
      กำลังสร้าง VerdeX ฟาร์มโรงเรือนอัจฉริยะสำหรับปลูก Sweet Basil
      โดยใช้ AI เป็นสมองกลางในการตัดสินใจและควบคุมอุปกรณ์ผ่าน Sensor ต่างๆ
      เพื่อให้ได้ผลผลิตสูงสุด
    </p>
    <p class="text-stone-600 dark:text-stone-400 leading-relaxed mb-4">
      Hi, I'm Prem — a solo entrepreneur based in Chiang Mai, Thailand.
      I'm building VerdeX, a smart greenhouse farm for growing Sweet Basil,
      powered by AI as the central decision-making system that controls
      equipment through various sensors — optimizing for the highest possible yield.
    </p>
    <p class="italic text-amber-700 dark:text-amber-400">
      "Reading and writing is the foundation."
    </p>

    <div class="mt-6">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm font-medium text-amber-700 dark:text-amber-400 hover:underline"
      >
        Read all posts
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- Thin divider -->
  <div class="max-w-2xl mx-auto px-4 sm:px-6">
    <hr class="border-stone-200 dark:border-stone-800" />
  </div>

  <!-- Recent posts -->
  <section class="max-w-2xl mx-auto px-4 sm:px-6 py-10">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-stone-400 dark:text-stone-500 mb-6">
      Recent Writing
    </h2>

    <div class="flex flex-col gap-4">
      {recentPosts.map((post) => (
        <PostCard
          slug={post.slug}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          readingTime={getReadingTime(post.body)}
          postType={post.data.postType}
        />
      ))}
    </div>

    {allPosts.length > 3 && (
      <div class="mt-6 text-center">
        <a
          href="/blog"
          class="text-sm text-stone-500 dark:text-stone-400 hover:text-amber-700 dark:hover:text-amber-400 transition-colors duration-150"
        >
          View all {allPosts.length} posts →
        </a>
      </div>
    )}
  </section>

  <!-- Tags cloud -->
  {allTags.length > 0 && (
    <section class="max-w-2xl mx-auto px-4 sm:px-6 pb-16">
      <div class="bg-white dark:bg-stone-900 rounded-xl border border-stone-200 dark:border-stone-800 p-6">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-stone-400 dark:text-stone-500 mb-4">
          Topics
        </h2>
        <div class="flex flex-wrap gap-2">
          {allTags.map((tag) => <TagBadge tag={tag} />)}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
