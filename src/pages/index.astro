---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../utils/reading-time';
import { siteConfig } from '../config';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const recentPosts = allPosts.slice(0, 5);

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteConfig.name,
  url: siteConfig.url,
  description: siteConfig.description,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteConfig.url}/blog?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title="VerdeX"
  description="Solo entrepreneur in Chiang Mai building VerdeX Farm — a smart hydroponic system for commercial herb growers. Writing about entrepreneurship, technology, and building in public."
  jsonLd={websiteJsonLd}
>
  <!-- Caveat font for quote -->
  <link slot="head" href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&display=swap" rel="stylesheet" />

  <main class="pt-20 px-6 md:px-12 max-w-7xl mx-auto space-y-24 pb-24">

    <!-- ═══ HERO — Terminal Window ═══ -->
    <section class="relative">
      <!-- Dot matrix background -->
      <div class="absolute inset-0 dot-matrix-bg" aria-hidden="true"></div>

      <div class="relative flex flex-col md:flex-row gap-0">
        <!-- Left panel — dark terminal -->
        <div class="md:w-2/3 p-8 md:p-12 relative" style="background-color: #0F3D32;">
          <!-- Window dots -->
          <div class="flex gap-2 mb-6" aria-hidden="true">
            <div class="w-2 h-2" style="background: #2E7D32;"></div>
            <div class="w-2 h-2" style="background: #2E7D32; opacity: 0.4;"></div>
            <div class="w-2 h-2" style="background: #2E7D32; opacity: 0.2;"></div>
          </div>

          <span class="font-display text-[10px] tracking-[0.25em] block mb-4 uppercase" style="color: #A8D3BF; opacity: 0.6;">
            SYSTEM_LOG // FEATURED_ENTRY
          </span>

          <h1 class="font-display text-4xl sm:text-5xl md:text-7xl font-bold tracking-tighter uppercase leading-none mb-8" style="color: #FAFAFA;">
            THE_HYDROPONIC<br/>FOUNDER<span class="blink-cursor"></span>
          </h1>

          <p class="text-base sm:text-lg leading-relaxed max-w-xl mb-6" style="color: rgba(168,211,191,0.8);">
            Interrogating the intersection of organic growth and silicon-based observation.
            If nature is the ultimate machine, smart farming is our first custom kernel.
          </p>

          <!-- System metadata -->
          <div class="grid grid-cols-2 gap-3 font-mono text-[10px] tracking-[0.15em] uppercase mb-10" style="color: rgba(250,250,250,0.4);">
            <div>READ_TIME: ∞</div>
            <div>LOC: CHIANG_MAI</div>
            <div>DATE: {new Date().toISOString().split('T')[0].replace(/-/g, '.')}</div>
            <div>STATUS: ACTIVE</div>
          </div>

          <a
            href="/blog"
            class="inline-block px-8 py-4 font-display font-bold uppercase tracking-widest text-xs transition-all duration-200 hover:opacity-90 phosphor-glow"
            style="background-color: #2E7D32; color: #0F3D32;"
          >
            EXECUTE_READ
          </a>
        </div>

        <!-- Right panel — accent image area -->
        <div class="md:w-1/3 min-h-[300px] md:min-h-[400px] relative overflow-hidden" style="background-color: #0a2e24;">
          <img
            src="/verdex-icon.png"
            alt=""
            class="absolute inset-0 w-full h-full object-contain opacity-20 p-16"
            style="mix-blend-mode: screen;"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, #0F3D32, transparent);"></div>
          <div class="absolute bottom-6 left-6 font-mono text-[10px] uppercase tracking-widest" style="color: rgba(250,250,250,0.25);">
            IMG_REF: VERDEX_CORE_001
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ SEQUENTIAL DATA FEED ═══ -->
    <section class="grid md:grid-cols-[1fr_2fr] gap-12 items-start">

      <!-- Left — sticky title -->
      <div class="md:sticky md:top-28 space-y-4">
        <h2 class="font-display text-3xl font-bold tracking-tighter uppercase leading-none">
          SEQUENTIAL<br/>DATA_FEED
        </h2>
        <p class="text-sm max-w-[240px]" style="color: var(--color-muted);">
          Chronological audit log of cognitive iterations and system updates.
        </p>
        <div class="pt-6 flex gap-1" aria-hidden="true">
          <div class="w-8 h-1" style="background: var(--color-primary);"></div>
          <div class="w-4 h-1" style="background: var(--color-border);"></div>
          <div class="w-2 h-1" style="background: var(--color-border);"></div>
        </div>
      </div>

      <!-- Right — post feed -->
      <div class="space-y-4">
        {recentPosts.map((post) => (
          <PostCard
            slug={post.slug}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            readingTime={getReadingTime(post.body)}
            postType={post.data.postType}
          />
        ))}

        {allPosts.length > 5 && (
          <a
            href="/blog"
            class="fetch-more-btn block w-full py-4 font-display text-xs tracking-[0.3em] uppercase text-center transition-colors duration-200"
          >
            FETCH_MORE_DATA
          </a>
        )}
      </div>

    </section>

    <!-- ═══ STOIC QUOTE — Dark terminal block ═══ -->
    <section class="p-8 md:p-16 relative overflow-hidden" style="background-color: #0F3D32;">
      <div class="absolute inset-0 dot-matrix-bg" aria-hidden="true" style="opacity: 0.1;"></div>
      <div class="relative max-w-3xl mx-auto text-center space-y-6">
        <span class="font-display text-[10px] tracking-[0.4em] uppercase" style="color: #2E7D32;">ENCRYPTED_WISDOM</span>
        <blockquote class="text-2xl sm:text-3xl md:text-4xl leading-snug" style="font-family: 'Caveat', cursive; color: #A8D3BF;">
          "The impediment to action advances action. What stands in the way becomes the way."
          <footer class="mt-4">
            <cite class="not-italic font-mono text-xs tracking-widest uppercase" style="color: rgba(168,211,191,0.5);">
              — MARCUS_AURELIUS // MEDITATIONS
            </cite>
          </footer>
        </blockquote>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .fetch-more-btn {
    border: 1px solid var(--color-border);
    color: var(--color-primary);
    background: transparent;
  }
  .fetch-more-btn:hover {
    background-color: var(--color-primary);
    color: #FAFAFA;
  }
  @media (prefers-reduced-motion: reduce) {
    .blink-cursor { animation: none; }
  }
</style>
