---
import BaseLayout from '../layouts/BaseLayout.astro';

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: "VerdeX",
  url: 'https://my-blog-kohl-one.vercel.app',
  description: 'Solo entrepreneur in Chiang Mai building VerdeX Farm — writing about entrepreneurship, hydroponics, and technology.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://my-blog-kohl-one.vercel.app/blog?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title="VerdeX"
  description="Solo entrepreneur in Chiang Mai building VerdeX Farm — a smart hydroponic system for commercial herb growers. Writing about entrepreneurship, technology, and building in public."
  jsonLd={websiteJsonLd}
>
  <!-- Hero — Medium-style oversized text -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-20 sm:pt-28 pb-10 sm:pb-14">
    <h1 class="text-5xl sm:text-7xl md:text-8xl font-bold leading-[1.1] tracking-tight mb-6" style="color: #1A3D2B; font-family: Georgia, 'Times New Roman', serif;">
      Read Then Write<br/>
      Then Read Then Write.....
    </h1>

    <!-- Y2K tattoo dots decoration -->
    <div class="flex items-center gap-0 my-8 select-none" aria-hidden="true">
      <span class="dot"></span><span class="dot"></span><span class="dot"></span>
      <span class="line-seg"></span>
      <span class="dot"></span><span class="dot"></span><span class="dot"></span>
      <span class="line-seg"></span>
      <span class="dot"></span><span class="dot"></span><span class="dot"></span>
    </div>

    <p class="text-stone-500 dark:text-stone-400 text-base sm:text-lg mb-8">
      Shared about me
    </p>
    <a
      href="/blog"
      class="inline-flex items-center px-8 py-3 rounded-full text-white font-medium text-base transition-all duration-200 hover:scale-105 hover:shadow-lg"
      style="background-color: #1A3D2B;"
    >
      Let goooo!
    </a>
  </section>

  <!-- Stoic quote — dark section -->
  <section class="w-full py-16 sm:py-20" style="background-color: #1A3D2B;">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <blockquote class="text-3xl sm:text-4xl md:text-5xl leading-snug mb-6" style="font-family: 'Caveat', cursive; color: #8BBFAA;">
        "The impediment to action advances action. What stands in the way becomes the way."
      </blockquote>
      <cite class="not-italic text-sm sm:text-base tracking-wide" style="font-family: 'Courier New', Courier, monospace; color: rgba(255,255,255,0.8);">
        — Marcus Aurelius, Meditations
      </cite>
    </div>

    <!-- Typewriter terminal animation -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 mt-12">
      <div class="rounded-lg p-4 sm:p-6" style="background-color: rgba(0,0,0,0.25);">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-3 h-3 rounded-full" style="background-color: #ff5f57;"></span>
          <span class="w-3 h-3 rounded-full" style="background-color: #febc2e;"></span>
          <span class="w-3 h-3 rounded-full" style="background-color: #28c840;"></span>
        </div>
        <p class="text-base sm:text-lg" style="font-family: 'Courier New', Courier, monospace; color: #8BBFAA;">
          <span class="opacity-60">&gt; </span><span id="typewriter-text"></span><span id="typewriter-cursor" style="color: #8BBFAA;">|</span>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Y2K tattoo dots */
  .dot {
    display: inline-block;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background-color: rgba(26, 61, 43, 0.3);
    margin: 0 3px;
  }
  .line-seg {
    display: inline-block;
    width: 28px;
    height: 1px;
    background-color: rgba(26, 61, 43, 0.3);
    margin: 0 3px;
    vertical-align: middle;
  }

  /* Cursor blink */
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  #typewriter-cursor {
    animation: blink 0.5s step-end infinite;
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    #typewriter-cursor {
      animation: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var el = document.getElementById('typewriter-text');
    if (!el) return;

    var phrases = ['Building VerdeX', 'Writing notes', 'Figuring it out'];
    var phraseIndex = 0;
    var charIndex = 0;
    var isDeleting = false;

    if (prefersReducedMotion) {
      el.textContent = phrases[0];
      return;
    }

    function tick() {
      var current = phrases[phraseIndex];

      if (!isDeleting) {
        charIndex++;
        el.textContent = current.substring(0, charIndex);
        if (charIndex === current.length) {
          setTimeout(function () { isDeleting = true; tick(); }, 2000);
          return;
        }
        setTimeout(tick, 80);
      } else {
        charIndex--;
        el.textContent = current.substring(0, charIndex);
        if (charIndex === 0) {
          isDeleting = false;
          phraseIndex = (phraseIndex + 1) % phrases.length;
          setTimeout(tick, 400);
          return;
        }
        setTimeout(tick, 40);
      }
    }

    tick();
  });
</script>
