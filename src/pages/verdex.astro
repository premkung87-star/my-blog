---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';

const milestones = [
  { status: 'done',    label: 'Research & concept validation' },
  { status: 'done',    label: 'Sensor selection (temp, humidity, soil moisture, light)' },
  { status: 'done',    label: 'AI decision engine architecture' },
  { status: 'current', label: 'Greenhouse prototype build in Chiang Mai' },
  { status: 'next',    label: 'First Sweet Basil grow cycle with AI control' },
  { status: 'next',    label: 'Yield data collection & optimization' },
  { status: 'next',    label: 'B2B pilot with local farms' },
];
---

<BaseLayout
  title="VerdeX"
  description="VerdeX — a smart greenhouse farm for growing Sweet Basil, powered by AI. Project status and milestones."
  jsonLd={{ '@context': 'https://schema.org', '@type': 'WebPage', name: 'VerdeX', url: `${siteConfig.url}/verdex` }}
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <img src="/verdex-icon.png" alt="" style="width: 48px; height: 48px; border-radius: 50%;" />
        <div>
          <h1 class="text-3xl font-bold text-stone-900 dark:text-stone-50">VerdeX</h1>
          <p class="text-sm text-stone-500 dark:text-stone-400">Smart Greenhouse Farm</p>
        </div>
      </div>
      <p class="text-stone-600 dark:text-stone-400 leading-relaxed" lang="th">
        ฟาร์ม Sweet Basil อัจฉริยะที่ควบคุมด้วย AI ผ่าน Sensor ต่างๆ
        เพื่อให้ได้ผลผลิตสูงสุดโดยอัตโนมัติ
      </p>
      <p class="text-stone-500 dark:text-stone-400 text-sm mt-2">
        A smart Sweet Basil farm powered by AI, using sensors to automate
        farm management for maximum yield.
      </p>
    </header>

    <!-- Tech Stack -->
    <section class="mb-10">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-stone-400 dark:text-stone-500 mb-4">
        Tech Stack
      </h2>
      <div class="flex flex-wrap gap-2">
        {['AI/ML', 'IoT Sensors', 'Temperature', 'Humidity', 'Soil Moisture', 'Light Sensor', 'Automated Control', 'Data Analytics'].map((tech) => (
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-stone-100 text-stone-600 dark:bg-stone-800 dark:text-stone-400">
            {tech}
          </span>
        ))}
      </div>
    </section>

    <!-- Milestones -->
    <section class="mb-10">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-stone-400 dark:text-stone-500 mb-4">
        Milestones
      </h2>
      <div class="flex flex-col gap-0">
        {milestones.map((m, i) => (
          <div class="flex items-start gap-3 relative">
            {/* Vertical line */}
            {i < milestones.length - 1 && (
              <div class="absolute left-[9px] top-5 bottom-0 w-px bg-stone-200 dark:bg-stone-700" />
            )}
            {/* Dot */}
            <div class:list={[
              'w-[19px] h-[19px] rounded-full flex-shrink-0 mt-0.5 border-2 relative z-10',
              m.status === 'done' ? 'bg-green-500 border-green-500' :
              m.status === 'current' ? 'bg-amber-500 border-amber-500 animate-pulse' :
              'bg-stone-200 dark:bg-stone-700 border-stone-300 dark:border-stone-600',
            ]} />
            <p class:list={[
              'text-sm pb-6',
              m.status === 'done' ? 'text-stone-500 dark:text-stone-400 line-through' :
              m.status === 'current' ? 'text-stone-900 dark:text-stone-50 font-medium' :
              'text-stone-400 dark:text-stone-500',
            ]}>
              {m.label}
              {m.status === 'current' && (
                <span class="ml-2 text-xs text-amber-600 dark:text-amber-400 font-normal">← current</span>
              )}
            </p>
          </div>
        ))}
      </div>
    </section>

    <!-- Location -->
    <section>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-stone-400 dark:text-stone-500 mb-4">
        Location
      </h2>
      <p class="text-sm text-stone-600 dark:text-stone-400">
        Chiang Mai, Thailand 🇹🇭
      </p>
    </section>
  </div>
</BaseLayout>
