---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';

const books = [
  {
    title: 'Stillness Is the Key',
    author: 'Ryan Holiday',
    note: 'สอนให้เราหยุด คิด และโฟกัสกับสิ่งที่สำคัญจริงๆ — ทักษะที่ entrepreneur ต้องมี',
    tags: ['Stoicism', 'Mindset'],
  },
  {
    title: 'How to Be Better at Almost Everything',
    author: 'Pat Flynn',
    note: 'ไม่ต้องเก่งที่สุดในสิ่งเดียว แค่เก่งพอในหลายๆ อย่างแล้วรวมมันเข้าด้วยกัน',
    tags: ['Skills', 'Generalist'],
  },
];
---

<BaseLayout
  title="Books"
  description="หนังสือที่ผมอ่านและแนะนำ — books that shaped how I think and build."
  jsonLd={{ '@context': 'https://schema.org', '@type': 'WebPage', name: 'Bookshelf', url: `${siteConfig.url}/books` }}
>
  <div class="pt-20 max-w-5xl mx-auto px-6 py-12 md:py-24">

    <div class="font-mono text-[10px] tracking-widest uppercase mb-2" style="color: var(--color-subtle);">
      // library / {books.length}_VOLUMES_INDEXED
    </div>
    <h1 class="font-display text-4xl sm:text-5xl font-bold tracking-tighter uppercase leading-none mb-4" style="color: var(--color-primary);">
      BOOKSHELF<span class="blink-cursor"></span>
    </h1>
    <p class="font-mono text-xs mb-12" style="color: var(--color-subtle);">
      // หนังสือที่อ่านแล้วอยากส่งต่อ — books I've read and recommend.
    </p>

    <div class="space-y-0" style="border-left: 1px solid var(--color-border);">
      {books.map((book, i) => (
        <div class="p-8 transition-colors duration-200 hover:translate-x-1" style="border-right: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); background: var(--color-surface);">
          <div class="flex justify-between items-start mb-4">
            <span class="font-mono text-[10px] tracking-widest uppercase" style="color: var(--color-subtle);">
              VOL_{String(i + 1).padStart(2, '0')}
            </span>
          </div>
          <h2 class="font-display text-xl font-bold uppercase tracking-tight mb-1" style="color: var(--color-primary);">
            {book.title.toUpperCase().replace(/\s+/g, '_')}
          </h2>
          <p class="font-mono text-xs mb-4" style="color: var(--color-subtle);">by {book.author}</p>
          <p class="text-sm leading-relaxed mb-4" lang="th" style="color: var(--color-muted);">
            {book.note}
          </p>
          <div class="flex flex-wrap gap-1">
            {book.tags.map((tag) => (
              <span class="font-mono text-[10px] uppercase tracking-widest px-2 py-0.5" style="color: #2E7D32; background: rgba(46,125,50,0.08);">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <p class="mt-10 font-mono text-[11px] italic" style="color: var(--color-subtle);">
      // เพิ่มเรื่อยๆ เมื่ออ่านจบ — updated as I finish more books.
    </p>
  </div>
</BaseLayout>
