---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';

const books = [
  {
    title: 'Stillness Is the Key',
    author: 'Ryan Holiday',
    note: 'สอนให้เราหยุด คิด และโฟกัสกับสิ่งที่สำคัญจริงๆ — ทักษะที่ entrepreneur ต้องมี',
    tags: ['Stoicism', 'Mindset'],
  },
  {
    title: 'How to Be Better at Almost Everything',
    author: 'Pat Flynn',
    note: 'ไม่ต้องเก่งที่สุดในสิ่งเดียว แค่เก่งพอในหลายๆ อย่างแล้วรวมมันเข้าด้วยกัน',
    tags: ['Skills', 'Generalist'],
  },
];
---

<BaseLayout
  title="Books"
  description="หนังสือที่ผมอ่านและแนะนำ — books that shaped how I think and build."
  jsonLd={{ '@context': 'https://schema.org', '@type': 'WebPage', name: 'Bookshelf', url: `${siteConfig.url}/books` }}
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-12">
    <header class="mb-10">
      <h1 class="text-3xl font-bold text-stone-900 dark:text-stone-50 mb-2">Bookshelf</h1>
      <p class="text-stone-500 dark:text-stone-400">
        หนังสือที่อ่านแล้วอยากส่งต่อ — books I've read and recommend.
      </p>
    </header>

    <div class="flex flex-col gap-6">
      {books.map((book) => (
        <div class="border border-stone-200 dark:border-stone-800 rounded-xl p-5 bg-white dark:bg-stone-900">
          <h2 class="text-lg font-semibold text-stone-900 dark:text-stone-50 mb-1">
            {book.title}
          </h2>
          <p class="text-sm text-stone-500 dark:text-stone-400 mb-3">
            by {book.author}
          </p>
          <p class="text-stone-700 dark:text-stone-300 text-sm leading-relaxed mb-3" lang="th">
            {book.note}
          </p>
          <div class="flex flex-wrap gap-1.5">
            {book.tags.map((tag) => (
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-stone-100 text-stone-600 dark:bg-stone-800 dark:text-stone-400">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <p class="mt-10 text-sm text-stone-400 dark:text-stone-500 italic">
      เพิ่มเรื่อยๆ เมื่ออ่านจบ — updated as I finish more books.
    </p>
  </div>
</BaseLayout>
